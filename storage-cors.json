  {
    "origin": [
      "https://line-event-manager.web.app",
      "https://line-event-manager.firebaseapp.com",
      "http://localhost:5000",
      "http://127.0.0.1:5000",
      "http://localhost:5001",
      "http://127.0.0.1:5001"
    ],
    "method": ["GET", "HEAD", "PUT", "POST", "DELETE", "OPTIONS"],
